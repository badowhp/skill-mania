{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(git checkout *)",
      "Bash(git clean *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git tag *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(sudo *)",
      "Bash(doas *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker *)",
      "Bash(podman *)",
      "Bash(terraform *)",
      "Bash(tofu *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(aws *)",
      "Bash(az *)",
      "Bash(gcloud *)",
      "Bash(gh *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn npm publish *)",
      "Bash(cargo publish *)",
      "Bash(gem push *)",
      "Bash(twine upload *)",
      "mcp__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(~/.aws/**)",
      "Read(~/.codex/auth.json)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.docker/config.json)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.ssh/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "denyRead": [
        "~/.aws",
        "~/.codex/auth.json",
        "~/.config/gh/hosts.yml",
        "~/.docker/config.json",
        "~/.gnupg",
        "~/.kube",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.ssh",
        ".env",
        ".env.local"
      ]
    },
    "credentials": {
      "files": [
        { "path": "~/.aws", "mode": "deny" },
        { "path": "~/.config/gh/hosts.yml", "mode": "deny" },
        { "path": "~/.docker/config.json", "mode": "deny" },
        { "path": "~/.gnupg", "mode": "deny" },
        { "path": "~/.kube", "mode": "deny" },
        { "path": "~/.ssh", "mode": "deny" }
      ],
      "envVars": [
        { "name": "ANTHROPIC_API_KEY", "mode": "deny" },
        { "name": "OPENAI_API_KEY", "mode": "deny" },
        { "name": "AWS_ACCESS_KEY_ID", "mode": "deny" },
        { "name": "AWS_SECRET_ACCESS_KEY", "mode": "deny" },
        { "name": "AWS_SESSION_TOKEN", "mode": "deny" },
        { "name": "GITHUB_TOKEN", "mode": "deny" },
        { "name": "GH_TOKEN", "mode": "deny" },
        { "name": "NPM_TOKEN", "mode": "deny" },
        { "name": "PYPI_API_TOKEN", "mode": "deny" }
      ]
    }
  },
  "disableAutoMode": "disable",
  "disableRemoteControl": true,
  "disableSkillShellExecution": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/templates/agent-automation/guard-agent-command.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
